---
import SectionContainer from "../../../components/styles/SectionContainer.astro";
import TextIntro from "../../styles/TextIntro.astro";
import VocabItem from "../../utils/VocabItem.astro";
---

<SectionContainer id="vocabulario-hiragana">
  <div class="w-[90%] md:w-[70%] mx-auto mb-8 text-center">
    <h3 class="text-2xl font-bold text-slate-800 mb-3">
      Vocabulario en Hiragana
    </h3>

    <p class="text-gray-600 font-mono text-sm">
      Las palabras están escritas en hiragana, y en rojo podés ver su
      pronunciación en español.
    </p>

    <!-- 🟢 Interacción -->
    <div
      class="mt-4 inline-block bg-green-50 text-green-700 text-xs font-bold px-4 py-2 rounded-full"
    >
      🔊 Tocá cada palabra para escuchar su pronunciación
    </div>
  </div>

  <!-- 🔴 Excepción -->
  <div
    class="w-[90%] md:w-[70%] mx-auto bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg mb-10"
  >
    <p class="text-red-700 text-sm font-mono leading-relaxed">
      ⚠️ En palabras como <span class="font-bold">こんにちは</span> y <span
        class="font-bold">こんばんは</span
      >, el carácter <span class="font-bold">は</span> se pronuncia <span
        class="font-bold">"wa"</span
      > en lugar de "ha". Veremos más adelante por qué sucede esto.
    </p>
  </div>
  <div class="w-[85%] md:w-[70%] mx-auto mt-5 font-mono flex flex-col gap-2">
    <VocabItem
      japanese="こんにちは"
      reading="konnichiwa"
      meaning="Buenas Tardes"
      audio="/audio/clase0/konnichiwa.mp3"
    />
    <VocabItem
      japanese="おはよう"
      reading="ohaiō"
      meaning="Buenos Días"
      audio="/audio/clase0/ohayou.mp3"
    />
    <VocabItem
      japanese="こんばんは"
      reading="konbanwa"
      meaning="Buenas Noches"
      audio="/audio/clase0/konbanwa.mp3"
    />
    <VocabItem
      japanese="さようなら"
      reading="saionara"
      meaning="Adiós"
      audio="/audio/clase0/saionara.mp3"
    />
    <VocabItem
      japanese="またね"
      reading="matane"
      meaning="Hasta Luego"
      audio="/audio/clase0/matane.mp3"
    />
    <VocabItem
      japanese="ごめんなさい"
      reading="gomennasai"
      meaning="Lo siento"
      audio="/audio/clase0/gomennasai.mp3"
    />
  </div>
</SectionContainer>

<script>
  const audioElements = document.querySelectorAll("[data-audio]");

  audioElements.forEach((element) => {
    element.addEventListener("click", () => {
      const audioSrc = element.getAttribute("data-audio");
      const audio = new Audio(audioSrc!);
      audio.play();
    });
  });
</script>
