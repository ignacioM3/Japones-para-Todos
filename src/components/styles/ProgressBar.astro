---
export interface Props {
  value?: number;
  max?: number;
  showLabel?: boolean;
  slug?: string;
}

const {
  value = 0,
  max = 100,
  showLabel = true,
} = Astro.props;

const percentage = Math.min(100, Math.max(0, (value / max) * 100));
---

<div
  class="relative w-full mt-4 h-4 bg-gray-200 rounded-full overflow-hidden"
  role="progressbar"
  aria-valuenow={value}
  aria-valuemin="0"
  aria-valuemax={max}
>
  <!-- Barra -->
  <div
    class="h-full rounded-full transition-all duration-500 ease-out
           bg-linear-to-r from-blue-500 to-indigo-600"
    style={`width: ${percentage}%`}
  />

  <!-- Label centrado -->
  {showLabel && (
    <div class={`absolute inset-0 flex items-center justify-center text-xs font-medium ${percentage > 45 ? 'text-white' : 'text-gray-500'}`}>
      {Math.round(percentage)}%
    </div>
  )}
</div>