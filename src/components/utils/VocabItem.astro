---
interface Props {
  japanese: string;
  reading: string;
  meaning: string;
  audio: string;
}

const { japanese, reading, meaning, audio } = Astro.props;
---

<div
  class="group cursor-pointer border-2 border-gray-100 rounded-xl p-6 bg-white hover:border-green-400 hover:shadow-md transition-all flex flex-col sm:flex-row items-center gap-6"
  data-audio={audio}
>
  {/* Sección del Kanji con Ruby para la lectura */}
  <div class="flex-shrink-0 text-center">
    <ruby class="text-2xl md:text-3xl font-bold text-slate-800 antialiased">
      {japanese} <rt class="text-xs uppercase tracking-widest text-red-500 font-medium mb-1">{reading}</rt>
    </ruby>
  </div>

  <div class="h-px w-full sm:h-12 sm:w-px bg-gray-200"></div>

  <div class="flex-grow text-center sm:text-left">
    <p class="text-sm uppercase tracking-tighter text-gray-400 font-semibold">Significado</p>
    <p class="text-xl text-gray-700 capitalize">{meaning}</p>
  </div>

  <div class="text-gray-300 group-hover:text-green-500 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
    </svg>
  </div>
</div>