---
interface Props {
  title: string;
  subTitle: string;
  info?: string;
}

const { title, info, subTitle } = Astro.props;
---

<section class="my-10 border-t-2 border-dashed border-gray-100 pt-12">
  <div class="text-center mb-10">
    <span class="text-xs font-bold uppercase tracking-[0.3em] text-green-500 block mb-2">{title}</span>
    <h3 class="text-3xl font-bold text-slate-800">
      {subTitle}
    </h3>
    <div class="h-1 w-12 bg-green-400 mx-auto mt-4 rounded-full"></div>
  </div>

  {info && (
    <div class="w-[85%] md:w-[70%] mx-auto bg-blue-50 border-l-4 border-blue-400 p-4 mb-8 rounded-r-lg">
      <p class="text-blue-700 text-sm leading-relaxed">
        {info}
      </p>
    </div>
  )}

 <div class="flex flex-wrap justify-center gap-3 sm:gap-6 w-[90%] md:w-[75%] mx-auto font-mono">
    <slot />
  </div>
</section>