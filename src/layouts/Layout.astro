---
import "../styles/global.css";

const { title = "Japones Para Todos" } = Astro.props;
import Header from "../components/utils/Header";
---

<script type="module">
	import "/src/utils/audio-init.ts";
</script>

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-100">
		<Header client:load />
		<slot />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		overscroll-behavior: none;
	}
</style>


<script type="module">
  import { initAsideProgress } from "/src/scripts/progressClient.ts";

  initAsideProgress();
</script>