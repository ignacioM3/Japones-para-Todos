---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Donaciones - Aprende Japonés">
  <main class="bg-gray-50 min-h-screen pb-20">
    <!-- HERO -->
    <section class="relative">
      <img
        src="/images/fondo1.jpg"
        class="h-[300px] md:h-[380px] w-full object-cover"
        alt="Imagen de fondo donaciones"
      />

      <div
        class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center text-center px-6"
      >
        <h1 class="font-lilita text-white text-4xl md:text-5xl">
          Apoya este proyecto
        </h1>

        <p class="text-gray-200 font-mono mt-4 max-w-[600px]">
          Este curso es gratuito para toda la comunidad. Si te resulta útil,
          puedes ayudarnos a seguir creando contenido para aprender japonés.
        </p>
      </div>
    </section>

    <!-- INFO -->
    <section class="max-w-[900px] mx-auto px-6 mt-14">
      <div class="bg-white rounded-xl shadow-md p-8">
        <h2 class="text-3xl font-bold text-center text-gray-700 mb-10">
          ¿Por qué apoyar el proyecto?
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="flex gap-4">
            <div class="text-3xl">📚</div>
            <div>
              <h3 class="font-bold text-gray-700">Contenido gratuito</h3>
              <p class="text-gray-600 text-sm">
                Todas las lecciones seguirán siendo gratis para la comunidad.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="text-3xl">🚀</div>
            <div>
              <h3 class="font-bold text-gray-700">Nuevas lecciones</h3>
              <p class="text-gray-600 text-sm">
                Tu apoyo ayuda a crear más contenido y ejercicios.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="text-3xl">🛠️</div>
            <div>
              <h3 class="font-bold text-gray-700">Mejoras en la web</h3>
              <p class="text-gray-600 text-sm">
                Podemos mejorar la plataforma y agregar nuevas funciones.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="text-3xl">❤️</div>
            <div>
              <h3 class="font-bold text-gray-700">Comunidad</h3>
              <p class="text-gray-600 text-sm">
                Ayudas a mantener un proyecto educativo abierto.
              </p>
            </div>
          </div>
        </div>

        <div
          class="mt-8 bg-yellow-50 border border-yellow-200 p-4 rounded-lg text-center text-sm text-yellow-800 font-mono"
        >
          Las donaciones son completamente voluntarias. El curso seguirá siendo
          gratuito para todos.
        </div>
      </div>
    </section>

    <!-- DONATION METHODS -->
    <section class="max-w-[1100px] mx-auto px-6 mt-14">
      <h2 class="text-3xl font-bold text-center text-gray-700 mb-10">
        Métodos de donación
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- PAYPAL -->
        <div
          class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition"
        >
          <div class="text-4xl mb-4">💰</div>

          <h3 class="text-xl font-bold text-gray-700 mb-2">PayPal</h3>

          <p class="text-gray-600 text-sm mb-5">
            Realiza una donación única de forma rápida.
          </p>

          <a
            href="https://paypal.me/IgnacioMarquez"
            target="_blank"
            class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-bold px-6 py-3 rounded-lg transition"
          >
            Donar con PayPal
          </a>
        </div>

        <!-- KOFI -->
        <div
          class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition"
        >
          <div class="text-4xl mb-4">☕</div>

          <h3 class="text-xl font-bold text-gray-700 mb-2">Ko-fi</h3>

          <p class="text-gray-600 text-sm mb-5">
            Invítanos un café para apoyar el proyecto.
          </p>

          <a
            href="https://ko-fi.com/tuusuario"
            target="_blank"
            class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold px-6 py-3 rounded-lg transition"
          >
            Apoyar en Ko-fi
          </a>
        </div>

        <!-- PATREON -->
        <div
          class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition"
        >
          <div class="text-4xl mb-4">⭐</div>

          <h3 class="text-xl font-bold text-gray-700 mb-2">Patreon</h3>

          <p class="text-gray-600 text-sm mb-5">
            Apoya el proyecto mensualmente.
          </p>

          <a
            href="https://patreon.com/tuusuario"
            target="_blank"
            class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-lg transition"
          >
            Unirse en Patreon
          </a>
        </div>
      </div>
    </section>

    <!-- CRYPTO -->
    <section class="max-w-[700px] mx-auto mt-16 px-6">
      <div class="bg-white rounded-xl shadow-md p-8">
        <h3 class="text-2xl font-bold text-gray-700 text-center mb-6">
          Donación con criptomonedas
        </h3>

        <div class="space-y-4 text-sm font-mono">
          <div>
            <p class="text-gray-600 mb-1">Bitcoin (BTC)</p>
            <p class="bg-gray-100 p-3 rounded break-all">
              bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
            </p>
          </div>

          <div>
            <p class="text-gray-600 mb-1">Ethereum (ETH)</p>
            <p class="bg-gray-100 p-3 rounded break-all">
              0x71C7656EC7ab88b098defB751B7401B5f6d8976F
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- THANK YOU -->
    <section class="text-center mt-20 px-6">
      <h2 class="text-2xl font-bold text-gray-700 mb-4">
        ¡Gracias por tu apoyo!
      </h2>

      <p class="text-gray-600 max-w-[600px] mx-auto">
        Cada contribución ayuda a mantener este proyecto educativo gratuito para
        personas que quieren aprender japonés.
      </p>

      <div class="text-5xl mt-6">🎌</div>
    </section>
  </main>
</Layout>
