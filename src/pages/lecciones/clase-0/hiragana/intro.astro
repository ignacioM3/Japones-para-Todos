---
import TextIntro from "../../../../components/styles/TextIntro.astro";
import { Icon } from "astro-icon/components";
import KanaGroup from "../../../../components/utils/KanaGroup.astro";
import KanaCard from "../../../../components/utils/KanaCard.astro";
import { getCollection } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import MainContainer from "../../../../components/styles/MainContainer.astro";
import { seccionesClase0 } from "../../../../lib/lessons";
import Aside from "../../../../components/utils/Aside.astro";
const hiragana = await getCollection("hiragana");

const sorted = hiragana.sort((a, b) =>
    a.id.localeCompare(b.id, undefined, { numeric: true }),
);

const hiraganaData = sorted[0];
const hiraganaData2 = sorted[1];
const hiraganaData3 = sorted[2];

---

<Layout title={"Clase 0 - Introducción a Hiragana"}>
    <MainContainer>
        <Aside sections={seccionesClase0} />
        <div class="mt-34 md:mt-30 max-w-175 w-full mb-10">
            <h2
                class="text-center font-semibold text-mono text-gray-500 text-2xl"
            >
                Introducción a Hiragana
            </h2>
            <TextIntro className="text-gray-600">
                Se trata de un silabario, lo que significa que cada carácter
                representa una sílaba en lugar de un sonido individual como en
                el alfabeto latino.
            </TextIntro>
            {
                hiraganaData.data.map((info) => (
                    <KanaGroup
                        title={info.title}
                        subTitle={info.subTitle}
                        info={info.info}
                    >
                        {info.kana.map((kana) => (
                            <KanaCard
                                kana={kana.kana}
                                romaji={kana.romaji}
                                isException={kana.isException}
                            />
                        ))}
                    </KanaGroup>
                ))
            }
            <div class="w-[90%] md:w-[70%] mx-auto space-y-10">
                <h3 class="text-2xl font-bold text-slate-800 text-center">
                    Tenten ゛ y Maru °
                </h3>

                <p class="text-center text-gray-600 font-mono text-sm">
                    Se usan para modificar el sonido de ciertas letras.
                </p>

                <!-- 🔴 TENTEN -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h4
                        class="text-lg text-center font-bold text-slate-800 mb-4"
                    >
                        Tenten ゛
                    </h4>

                    <p class="text-sm text-gray-600 font-mono mb-6 text-center">
                        Por ejemplo acá cambiamos el sonido de la "KA" a "GA".
                        Esto se aplica a las filas K, S, T y H.
                    </p>

                    <div class="grid sm:grid-cols-3 gap-4 text-center">
                        <div class="bg-gray-50 p-4 rounded-xl">
                            <p class="text-2xl">か</p>
                            <p class="text-xs text-gray-500">ka</p>
                        </div>

                        <div
                            class="flex items-center justify-center text-gray-400 font-bold"
                        >
                            <Icon
                                name="heroicons:arrow-right"
                                class="text-2xl"
                            />
                        </div>

                        <div
                            class="bg-red-50 border border-red-200 p-4 rounded-xl"
                        >
                            <p class="text-2xl text-red-600">が</p>
                            <p class="text-xs text-red-500 font-bold">ga</p>
                        </div>
                    </div>
                </div>

                <!-- 🟣 MARU -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h4
                        class="text-lg text-center font-bold text-slate-800 mb-4"
                    >
                        Maru °
                    </h4>

                    <p class="text-sm text-gray-600 font-mono mb-6 text-center">
                        Por ejemplo acá cambiamos el sonido de la "HA" a "PA".
                        Esto se aplica a las filas H.
                    </p>

                    <div class="grid sm:grid-cols-3 gap-4 text-center">
                        <div class="bg-gray-50 p-4 rounded-xl">
                            <p class="text-2xl">は</p>
                            <p class="text-xs text-gray-500">ha</p>
                        </div>

                        <div
                            class="flex items-center justify-center text-gray-400 font-bold"
                        >
                            <Icon
                                name="heroicons:arrow-right"
                                class="text-2xl"
                            />
                        </div>

                        <div
                            class="bg-purple-50 border border-purple-200 p-4 rounded-xl"
                        >
                            <p class="text-2xl text-purple-600">ぱ</p>
                            <p class="text-xs text-purple-500 font-bold">pa</p>
                        </div>
                    </div>
                </div>
            </div>
            {
                hiraganaData2.data.map((info) => (
                    <KanaGroup
                        title={info.title}
                        subTitle={info.subTitle}
                        info={info.info}
                    >
                        {info.kana.map((kana) => (
                            <KanaCard
                                kana={kana.kana}
                                romaji={kana.romaji}
                                isException={kana.isException}
                            />
                        ))}
                    </KanaGroup>
                ))
            }
            <div class="w-[90%] md:w-[70%] mx-auto">
                <h3 class="text-2xl font-bold text-slate-800 text-center mb-6">
                    Fusionando sonidos: や・ゆ・よ pequeños
                </h3>

                <!-- Explicación corta -->
                <p
                    class="text-gray-600 font-mono text-sm leading-relaxed mb-6 text-center"
                >
                    や (ya), ゆ (yu) y よ (yo) pueden hacerse pequeños para
                    combinarse con otros kana y crear nuevos sonidos.
                </p>

                <!-- 🔥 Visual clave -->
                <div
                    class="flex items-center justify-center gap-4 mb-8 text-center"
                >
                    <div class="bg-white border rounded-xl p-4">
                        <p class="text-3xl">き</p>
                        <p class="text-xs text-gray-500">ki</p>
                    </div>

                    <span class="text-xl font-bold text-gray-400">+</span>

                    <div class="bg-white border rounded-xl p-4">
                        <p class="text-3xl">ょ</p>
                        <p class="text-xs text-gray-500">yo (pequeño)</p>
                    </div>

                    <span class="text-xl font-bold text-gray-400">→</span>

                    <div
                        class="bg-green-50 border-2 border-green-300 rounded-xl p-4"
                    >
                        <p class="text-3xl font-bold text-green-700">きょ</p>
                        <p class="text-xs text-green-600 font-bold">kyo</p>
                    </div>
                </div>

                <!-- Explicación extendida (tu contenido, pero dividido) -->
                <p class="text-gray-600 font-mono text-sm leading-relaxed mb-4">
                    Esto permite representar sonidos como "kyo", que no
                    podríamos escribir con kana básicos.
                </p>

                <div
                    class="bg-gray-50 rounded-lg p-4 text-sm font-mono text-gray-700 mb-4"
                >
                    Ejemplo: "Kyou" (hoy) necesita el sonido "kyo"
                </div>

                <p class="text-gray-600 font-mono text-sm leading-relaxed">
                    Es similar a cómo en español combinamos sonidos al decir
                    "hoy".
                </p>
            </div>
            {
                hiraganaData3.data.map((info) => (
                    <KanaGroup
                        title={info.title}
                        subTitle={info.subTitle}
                        info={info.info}
                    >
                        {info.kana.map((kana) => (
                            <KanaCard
                                kana={kana.kana}
                                romaji={kana.romaji}
                                isException={kana.isException}
                            />
                        ))}
                    </KanaGroup>
                ))
            }

            <div class="w-[90%] md:w-[70%] mx-auto space-y-10">
                <!-- 🔵 BLOQUE 1: VOCALES LARGAS -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h4 class="text-xl font-bold text-slate-800 mb-3">
                        Vocales largas: おう / えい
                    </h4>

                    <p
                        class="text-gray-600 font-mono text-sm leading-relaxed mb-6"
                    >
                        Combinaciones como おう y えい representan vocales
                        largas. Aunque antes se pronunciaban separadas, hoy
                        suenan como una sola vocal extendida (Ō / Ē).
                    </p>

                    <div class="grid sm:grid-cols-2 gap-4">
                        <!-- ITEM -->
                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/arigatou.mp3"
                                name="sound"
                                class="text-xl cursor-pointer hover:text-green-600"
                            />
                            <div>
                                <p class="text-lg font-semibold">ありがとう</p>
                                <p class="text-blue-500 font-bold text-sm">
                                    ARIGATŌ
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/koukou.mp3"
                                name="sound"
                                class="text-xl cursor-pointer hover:text-green-600"
                            />
                            <div>
                                <p class="text-lg font-semibold">こうこう</p>
                                <p class="text-blue-500 font-bold text-sm">
                                    KŌKŌ
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 🟣 BLOQUE 2: っ PEQUEÑA -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h4 class="text-xl font-bold text-slate-800 mb-3">
                        っ pequeña (consonante doble)
                    </h4>

                    <p
                        class="text-gray-600 font-mono text-sm leading-relaxed mb-6"
                    >
                        La っ indica una pausa corta antes de la consonante
                        siguiente, duplicando su sonido. Solo se usa con K, S, T
                        y P.
                    </p>

                    <div class="grid sm:grid-cols-2 gap-4 mb-6">
                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/kite.mp3"
                                name="sound"
                                class="text-xl cursor-pointer hover:text-green-600"
                            />
                            <div>
                                <p class="text-lg font-semibold">きて</p>
                                <p class="text-blue-500 font-bold text-sm">
                                    kite
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-red-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/kitte.mp3"
                                name="sound"
                                class="text-xl cursor-pointer hover:text-green-600"
                            />
                            <div>
                                <p class="text-lg font-semibold">きって</p>
                                <p class="text-blue-500 font-bold text-sm">
                                    KITTE
                                </p>
                            </div>
                        </div>
                    </div>

                    <p class="text-sm text-gray-600 mb-6">
                        La diferencia está en la pausa antes de la "t".
                    </p>

                    <!-- Ejemplos -->
                    <div class="grid sm:grid-cols-3 gap-4">
                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/gakkou.mp3"
                                name="sound"
                                class="text-xl cursor-pointer"
                            />
                            <div>
                                <p class="font-semibold">がっこう</p>
                                <p class="text-blue-500 text-sm font-bold">
                                    GAKKŌ
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/sasshi.mp3"
                                name="sound"
                                class="text-xl cursor-pointer"
                            />
                            <div>
                                <p class="font-semibold">ざっし</p>
                                <p class="text-blue-500 text-sm font-bold">
                                    ZASSHI
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <Icon
                                data-audio="/audio/clase0/kippu.mp3"
                                name="sound"
                                class="text-xl cursor-pointer"
                            />
                            <div>
                                <p class="font-semibold">きっぷ</p>
                                <p class="text-blue-500 text-sm font-bold">
                                    KIPPU
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <a
                href="/lecciones/clase-0/hiragana/vocabulario"
                id="complete-btn"
                class="mx-auto my-10 block w-max px-15 py-2 bg-green-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-green-600"
            >
                Siguiente
            </a>
        </div>
    </MainContainer>
</Layout>


<script>
  import { initCompleteButton } from "../../../../scripts/progressClient";

  document.addEventListener("DOMContentLoaded", () => {
    initCompleteButton("complete-btn", "hiragana-intro");
  });
</script>