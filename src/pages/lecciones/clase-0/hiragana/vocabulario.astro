---
import VocabItem from "../../../../components/utils/VocabItem.astro";
import Layout from "../../../../layouts/Layout.astro";
import Aside from "../../../../components/utils/Aside.astro";
import { seccionesClase0 } from "../../../../lib/lessons";
import MainContainer from "../../../../components/styles/MainContainer.astro";


---

<Layout>
    <MainContainer>
    <Aside sections={seccionesClase0} />
    
    <div class="mt-34 md:mt-30 max-w-175 w-full mb-10">
        <div class="w-[90%] md:w-[70%] mx-auto mb-8 text-center">
            <h3 class="text-2xl font-bold text-slate-800 mb-3">
                Vocabulario en Hiragana
            </h3>

            <p class="text-gray-600 font-mono text-sm">
                Las palabras están escritas en hiragana, y en rojo podés ver su
                pronunciación en español.
            </p>

            <!-- 🟢 Interacción -->
            <div
                class="mt-4 inline-block bg-green-50 text-green-700 text-xs font-bold px-4 py-2 rounded-full"
            >
                🔊 Tocá cada palabra para escuchar su pronunciación
            </div>
        </div>

        <!-- 🔴 Excepción -->
        <div
            class="w-[90%] md:w-[70%] mx-auto bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg mb-10"
        >
            <p class="text-red-700 text-sm font-mono leading-relaxed">
                ⚠️ En palabras como <span class="font-bold">こんにちは</span> y <span
                    class="font-bold">こんばんは</span
                >, el carácter <span class="font-bold">は</span> se pronuncia <span
                    class="font-bold">"wa"</span
                > en lugar de "ha". Veremos más adelante por qué sucede esto.
            </p>
        </div>
        <div
            class="w-[85%] md:w-[70%] mx-auto mt-5 font-mono flex flex-col gap-2"
        >
            <VocabItem
                japanese="こんにちは"
                reading="konnichiwa"
                meaning="Buenas Tardes"
                audio="/audio/clase0/konnichiwa.mp3"
            />
            <VocabItem
                japanese="おはよう"
                reading="ohaiō"
                meaning="Buenos Días"
                audio="/audio/clase0/ohayou.mp3"
            />
            <VocabItem
                japanese="こんばんは"
                reading="konbanwa"
                meaning="Buenas Noches"
                audio="/audio/clase0/konbanwa.mp3"
            />
            <VocabItem
                japanese="さようなら"
                reading="saionara"
                meaning="Adiós"
                audio="/audio/clase0/saionara.mp3"
            />
            <VocabItem
                japanese="またね"
                reading="matane"
                meaning="Hasta Luego"
                audio="/audio/clase0/matane.mp3"
            />
            <VocabItem
                japanese="ごめんなさい"
                reading="gomennasai"
                meaning="Lo siento"
                audio="/audio/clase0/gomennasai.mp3"
            />
        </div>

        <div class="flex items-center justify-between w-[90%] md:w-[70%] mx-auto mt-10">
            <a
                href="/lecciones/clase-0/hiragana/intro"
                class="mx-auto my-10 block w-max px-12 md:px-17 py-2 bg-gray-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-gray-600"
            >
                Volver
            </a>
            <a
                href="/lecciones/clase-0/hiragana/tarea"
                id="complete-btn"
                class="mx-auto my-10 block w-max px-10 md:px-15 py-2 bg-green-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-green-600"
            >
                Siguiente
            </a>
        </div>
    </div>
    </MainContainer>
</Layout>


<script>
  import { initCompleteButton } from "../../../../scripts/progressClient";

  document.addEventListener("DOMContentLoaded", () => {
    initCompleteButton("complete-btn", "hiragana-vocab");
  });
</script>

