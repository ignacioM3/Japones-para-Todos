---
import TextIntro from "../../../../components/styles/TextIntro.astro";
import { Icon } from "astro-icon/components";
import Layout from "../../../../layouts/Layout.astro";
import MainContainer from "../../../../components/styles/MainContainer.astro";
import Aside from "../../../../components/utils/Aside.astro";
import { seccionesClase0 } from "../../../../lib/lessons";
---

<Layout title={"Clase 0 - Tarea de Hiragana"}>
    <MainContainer>
        <Aside sections={seccionesClase0} />
        <div class="mt-34 md:mt-30 max-w-175 w-full mb-10">
            <h2 class="text-center font-semibold text-gray-500 text-2xl">
                Tarea Hiragana
            </h2>

            <TextIntro className="text-gray-600">
                Practicar constantemente es clave. Estas tareas están pensadas
                para reforzar lectura, escritura y pronunciación.
            </TextIntro>

            <div class="w-[90%] md:w-[70%] mx-auto space-y-6 mt-8">
                <!-- 📝 Paso 1 -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h3 class="font-bold text-slate-800 mb-2">
                        1. Escritura básica
                    </h3>
                    <p class="text-sm text-gray-600 font-mono">
                        Repetí cada letra del hiragana al menos 10 veces en
                        papel.
                    </p>
                </div>

                <!-- 🎵 Paso 2 -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h3 class="font-bold text-slate-800 mb-2">
                        2. Práctica con canciones
                    </h3>

                    <p class="text-sm text-gray-600 font-mono mb-4">
                        Escribí en hiragana partes de canciones. No importa la
                        traducción, enfocate en la escritura.
                    </p>

                    <div class="space-y-3">
                        <a
                            href="https://www.youtube.com/watch?v=855pQECcbxI"
                            target="_blank"
                            class="flex items-center justify-between p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <span class="text-sm font-medium">
                                Sakura Anata ni Deaete Yokatta
                            </span>
                            <Icon name="heroicons:play" />
                        </a>

                        <a
                            href="https://www.youtube.com/watch?v=SJywJjwqIK8"
                            target="_blank"
                            class="flex items-center justify-between p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <span class="text-sm font-medium">
                                Kimi ga Kureta Mono
                            </span>
                            <Icon name="heroicons:play" />
                        </a>

                        <a
                            href="https://www.youtube.com/watch?v=JdSpuTi9d8A"
                            target="_blank"
                            class="flex items-center justify-between p-3 rounded-xl bg-gray-50 hover:bg-green-50 transition"
                        >
                            <span class="text-sm font-medium">
                                Shigatsu wa Kimi no Uso Opening
                            </span>
                            <Icon name="heroicons:play" />
                        </a>
                    </div>
                </div>

                <!-- 🎤 Paso 3 -->
                <div
                    class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
                >
                    <h3 class="font-bold text-slate-800 mb-2">
                        3. Lectura + pronunciación
                    </h3>

                    <p class="text-sm text-gray-600 font-mono">
                        Intentá cantar leyendo lo que escribiste. Equivocarte es
                        parte del proceso: detectá errores y volvé a intentar.
                    </p>
                </div>
               
            </div>
             <div
                    class="flex items-center justify-between w-[90%] md:w-[70%] mx-auto mt-10"
                >
                    <a
                        href="/lecciones/clase-0/hiragana/vocabulario"
                        class="mx-auto my-10 block w-max px-12 md:px-17 py-2 bg-gray-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-gray-600"
                    >
                        Volver
                    </a>
                    <a
                        href="/lecciones/clase-0/katakana/intro"
                        id="complete-btn"
                        class="mx-auto my-10 block w-max px-10 md:px-15 py-2 bg-green-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-green-600"
                    >
                        Siguiente
                    </a>
                </div>
        </div>
    </MainContainer>
</Layout>



<script type="module">
  import { initCompleteButton } from "../../../../scripts/progressClient.ts";

  initCompleteButton("complete-btn", "hiragana-task");
</script>
