---
import MainContainer from "../../../../components/styles/MainContainer.astro";
import Aside from "../../../../components/utils/Aside.astro";
import Layout from "../../../../layouts/Layout.astro";
import { seccionesClase0 } from "../../../../lib/lessons";
import TextIntro from "../../../../components/styles/TextIntro.astro";
---

<Layout title={"Clase 0 - Tarea de Katakana"}>
  <MainContainer>
    <Aside sections={seccionesClase0} />
    <div class="mt-34 md:mt-30 max-w-175 w-full mb-10">
      <h2 class="text-center font-semibold text-gray-500 text-2xl">
        Tarea Katakana
      </h2>

      <TextIntro className="text-gray-600">
        Katakana se usa en la vida real constantemente. Estas tareas te ayudan a
        reconocerlo rápidamente.
      </TextIntro>

      <div class="w-[90%] md:w-[70%] mx-auto space-y-6 mt-8">
        <!-- 👁️ Paso 1 -->
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-800 mb-2">
            1. Reconocimiento visual
          </h3>
          <p class="text-sm text-gray-600 font-mono">
            Buscá palabras en katakana en internet (marcas, productos, anime) e
            intentá leerlas sin ayuda.
          </p>
        </div>

        <!-- 🔤 Paso 2 -->
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-800 mb-2">
            2. Escribí palabras extranjeras
          </h3>

          <p class="text-sm text-gray-600 font-mono">
            Intentá escribir en katakana palabras como:
          </p>

          <div
            class="mt-4 bg-gray-50 p-4 rounded-xl text-sm font-mono text-gray-700"
          >
            • computadora <br />
            • café <br />
            • televisión <br />
            • pizza
          </div>
        </div>

        <!-- 🎤 Paso 3 -->
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-slate-800 mb-2">3. Pronunciación</h3>

          <p class="text-sm text-gray-600 font-mono">
            Leé en voz alta palabras en katakana. Intentá imitar la
            pronunciación japonesa.
          </p>
        </div>
      </div>
      <div
        class="flex items-center justify-between w-[90%] md:w-[70%] mx-auto mt-10"
      >
        <a
          href="/lecciones/clase-0/katakana/vocabulario"
          class="mx-auto my-10 block w-max px-12 md:px-17 py-2 bg-gray-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-gray-600"
        >
          Volver
        </a>
        <a
          href="/lecciones/"
          id="complete-btn"
          class="mx-auto my-10 block w-max px-10 md:px-15 py-2 bg-green-500 text-white rounded-md text-lg font-medium transition-colors duration-300 hover:bg-green-600"
        >
          Finalizar Lección
        </a>
      </div>
    </div>
  </MainContainer>
</Layout>


<script type="module">
  import { initCompleteButton } from "../../../../scripts/progressClient.ts";

  initCompleteButton("complete-btn", "katakana-task");
</script>
